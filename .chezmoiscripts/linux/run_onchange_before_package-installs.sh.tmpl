#!/bin/sh
# vim: set filetype=sh:

SUDO="$(command -v doas)"
if [ -z "${SUDO}" ]; then
	SUDO="$(command -v sudo)"
fi

{{ if eq .chezmoi.osRelease.id "fedora" -}}
{{ range or (.packages.fedora.copr (list)) -}}
${SUDO} dnf copr enable -y {{ . | quote }}
{{ end }}

if ! rpm -qi rpmfusion-free-release-{{ .chezmoi.osRelease.versionID }} >/dev/null 2>&1; then
	${SUDO} dnf install -y https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-{{ .chezmoi.osRelease.versionID }}.noarch.rpm
fi
if ! rpm -qi rpmfusion-nonfree-release-{{ .chezmoi.osRelease.versionID }} >/dev/null 2>&1; then
	${SUDO} dnf install -y https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-{{ .chezmoi.osRelease.versionID }}.noarch.rpm
fi
if ! rpm -qi rpmfusion-nonfree-release-tainted-{{ .chezmoi.osRelease.versionID }} >/dev/null 2>&1; then
	${SUDO} dnf install -y https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-tainted-{{ .chezmoi.osRelease.versionID }}.noarch.rpm
fi
${SUDO} dnf install -y rpmfusion-free-appstream-data rpmfusion-nonfree-appstream-data

{{ with dig "packages" "fedora" "removal" (list) . -}}
${SUDO} dnf remove -y {{ . | join " " }}
{{- end }}
{{ with dig "packages" "fedora" "dnf" (list) . -}}
${SUDO} dnf install -y {{ . | join " " }}
{{- end }}
{{ else if eq .chezmoi.osRelease.id "arch" -}}
{{- $pkgs := dig "packages" "arch" "pacman" (list) . -}}
{{ if lookPath "yay" -}}
	{{- $pkgs = uniq (concat $pkgs (dig "packages" "arch" "aur" (list) .)) -}}
	{{ with $pkgs -}}
	yay -Sy --needed --noconfirm --removemake --answerclean NotInstalled --answerdiff None --answeredit None --norebuild --noredownload {{ . | join " " }}
	{{- end }}
{{ else }}
	{{ with $pkgs -}}
	${SUDO} pacman -Sy --needed --noconfirm {{ . | join " " }}
	{{- end }}
{{- end }}
{{ else if eq .chezmoi.osRelease.id "debian" -}}
{{ with dig "packages" "debian" "removal" (list) . -}}
${SUDO} apt-get remove -y {{ . | join " " }}
{{- end }}
{{ with dig "packages" "debian" "apt" (list) . -}}
${SUDO} apt-get install -y {{ . | join " " }}
{{- end }}
{{ end }}

{{ if lookPath "flatpak" }}
{{ range uniq (concat
	(or (index .packages .chezmoi.osRelease.id "flatpak") (list))
	(or .packages.common.flatpak (list))
) -}}
flatpak install -y {{ .remote }} {{ .name }}
{{ end -}}
{{ end }}
