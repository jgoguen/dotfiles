#:schema https://docs.jj-vcs.dev/latest/config-schema.json

[aliases]
bottom = ["edit", "stack_bottom()"]
push = ["git", "push", "-c", "trunk()..@"]
top = ["edit", "stack_top()"]

[colors]
"diff removed token" = { fg = "bright red", bg = "#400000", underline = false }
"diff added token" = { fg = "bright green", bg = "#003000", underline = false }

[git]
sign-on-push = true

[remotes.origin]
auto-track-bookmarks = "{{ .chezmoi.username }}/*"

[remotes.upstream]
auto-track-bookmarks = "{{ .chezmoi.username }}/*"

[revset-aliases]
# Commits in the current stack: ancestors of @ that are not ancestors of trunk()
"stack_range()" = "trunk()..@"

# Bottom of stack: first descendant of trunk() on the path to @
"stack_bottom()" = "roots(stack_range())"

# Top of stack: head commit of that path
"stack_top()" = "heads(stack_range())"

[signing]
behavior = "own"
backend = "ssh"
backends.ssh.allowed-signers = "{{ .chezmoi.homeDir }}/.config/git/allowed_signers"
{{- if ne .environment "headless" }}
{{- if eq .chezmoi.os "darwin" }}
backends.ssh.program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- else if eq .chezmoi.os "windows" }}
backends.ssh.program = "{{ .chezmoi.homeDir }}/AppData/Local/1Password/app/8/op-ssh-sign.exe"
{{- else }}
backends.ssh.program = "/opt/1Password/op-ssh-sign"
{{- end }}
{{- end }}
key = "{{ .github.gpgkey }}"

[template-aliases]
"in_branch(commit)" = 'commit.contained_in("immutable_heads()..bookmarks()")'

[templates]
git_push_bookmark = '"{{ .chezmoi.username }}/" ++ change_id.shortest(8)'
log_node = '''
coalesce(
	if(!self, "🮀"),
	if(conflict, "⚠"),
	if(current_working_copy, "@"),
	if(root, "┴"),
	if(immutable, "●"),
	if(in_branch(self), "◇"),
	"○"
)
'''
op_log_node = 'if(current_operation, "@", "○")'

[ui]
default-command = "log"
diff-format = "git"
log-word-wrap = true

[user]
name = "Joel Goguen"
email = "{{ .email }}"
