# vim: set filetype=gitconfig:
# Do not edit this file directly! It is managed by chezmoi.

[advice]
	skippedCherryPicks = false

[alias]
	branches = branch -a -l
	cgrep = "!f() { \
		if [ $# -lt 1 ]; then \
			echo "usage: git cgrep <pattern> [pathspec ...]"; \
			return 1; \
		fi; \
		pattern=\"$1\"; shift; \
		git log -p -G \"${pattern}\" -- \"$@\"; \
	}; f"
	changed-files =	"!f() { \
		if [ \"$#\" -gt 0 ]; then \
			base = \"$1\"; \
		else \
			up=$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true); \
			if [ -n \"${up}\" ]; then \
				base=$(git merge-base HEAD \"${up}\"); \
			else \
				def_head=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true); \
				if [ -n \"${def_head}\" ]; then \
					base=$(git merge-base HEAD \"${def_head}\"); \
				elif git rev-parse --verify main >/dev/null 2>&1; then \
					base=$(git merge-base HEAD main); \
				elif git rev-parse --verify master >/dev/null 2>&1; then \
					base=$(git merge-base HEAD master); \
				else \
					base=$(git rev-list --max-parents=0 HEAD | tail -n 1); \
				fi; \
			fi; \
		fi; \
		{ \
			git diff --name-status \"${base}\"; \
			git ls-files --others --exclude-standard | sed 's/^/x\t/'; \
		} | sort -k2 -u; \
	}; f"
	delete-merged = "!f() { \
		HEAD_BRANCH=\"$(git remote show origin | awk '/HEAD branch/ {print $NF}')\"; \
		git fetch -p; \
		git for-each-ref refs/heads/ --format='%(refname:short)%(HEAD) %(upstream:track)' | \
			grep -v '\\*' | \
			awk '/\\[gone\\]/ {print $1}' | \
			while read branch; do \
				git branch -D \"${branch}\"; \
			done; \
	}; f"
	discard = reset --hard HEAD
	dm = delete-merged
	fdiff = "changed-files"
	irebase = !f() { git rebase -i HEAD~$1; }; f
	latest = "!f() { \
		curr=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo ""); \
		had_shelf=0; \
		if [ -n "$(git status --porcelain=v1 2>/dev/null)" ]; then \
			git shelve || { echo "[latest] git shelve failed"; return 1; }; \
			had_shelf=1; \
		fi; \
		git trunk; \
		trunk=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo ""); \
		if [ -z "${trunk}" ]; then \
			echo "[latest] failed to determine trunk branch"; \
			return 1; \
		fi; \
		was_feature=0; \
		if [ -n "${curr}" ] && [ "${curr}" != "${trunk}" ]; then was_feature=1; fi; \
		git pull || { echo "[latest] git pull failed"; return 1; }; \
		git submodule update --recursive || { echo "[latest] submodule update failed"; return 1; }; \
		if [ "${was_feature}" = 1 ]; then \
			git switch "${curr}" || { echo "[latest] Cannot switch back to ${curr}"; return 1; }; \
			echo "[latest] Rebasing stack onto ${trunk}..."; \
			git rebase "${trunk}" || { \
				echo "[latest] Rebase failed, resolve conflicts manually and continue/abort rebase."; \
				echo "[latest] Stashed changes are still saved, do NOT run git stash pop yet."; \
				return 1; \
			}; \
		fi; \
		git delete-merged || { echo "[latest] git delete-merged failed"; return 1; }; \
		if [ "${had_shelf}" = 1 ]; then \
			git unshelve || { echo "[latest] git unshelve failed, you may have stashed changes that need to be manually unstashed."; return 1; }; \
		fi; \
	}; f"
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	outdated = !git-rebase-needed
	qup = "!f() { \
		if [ -z \"${1}\" ]; then \
			return; \
		fi; \
		git switch ${1}; \
	}; \
	HEAD_BRANCH=\"$(git remote show origin | awk '/HEAD branch/ {print $NF}')\"; \
	f $(git for-each-ref --sort=-committerdate refs/heads/ --format='%(objectname:short) %(HEAD)%(refname:short)' | grep -Ev \"\\*|\\s${HEAD_BRANCH}$\" | fzf --layout=reverse-list --select-1 | awk '{print $2}')"
	remotes = remote -v
	shelve = stash push --include-untracked
	sl = "sl-all --author \"$(git config user.email)\""
	sl-all = "log --graph --boundary --decorate --color=always --abbrev-commit--date=relative --simplify-by-decoration --all --not origin/HEAD --pretty=format:'%C(auto)%h %C(bold blue)%ar%C(reset) %C(yellow)%d%C(reset) %s'"
	trunk = "!f() { \
		if def_head=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null); then \
			TRUNK_BRANCH=${def_head#origin/}; \
		elif git show-ref --verify --quiet refs/heads/main >/dev/null 2>&1; then \
			TRUNK_BRANCH=main; \
		elif git show-ref --verify --quiet refs/heads/master >/dev/null 2>&1; then \
			TRUNK_BRANCH=master; \
		elif git show-ref --verify --quiet refs/remotes/origin/main >/dev/null 2>&1; then \
			TRUNK_BRANCH=main; \
		elif git show-ref --verify --quiet refs/remotes/origin/master >/dev/null 2>&1; then \
			TRUNK_BRANCH=master; \
		else \
			echo 'Could not determine trunk branch (tried origin/HEAD, main, master)' >&2; \
			exit 1; \
		fi; \
		if ! git show-ref --verify --quiet \"refs/heads/$TRUNK_BRANCH\"; then \
			git branch \"${TRUNK_BRANCH}\" \"origin/${TRUNK_BRANCH}\" 2>/dev/null || true; \
		fi; \
		git switch \"${TRUNK_BRANCH}\"; \
	}; f"
	unstage = reset
	uncommit = reset --soft HEAD^
	unshelve = stash pop

[apply]
	whitespace = fix

[blame]
	date = iso-local

[branch]
	autosetuprebase = always
	autosetupmerge = true

[color]
	ui = true

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	frag = magenta bold
	meta = yellow bold
	new = green bold
	old = red bold
	whitespace = red reverse

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[column]
	ui = auto

[commit]
	gpgsign = true
	template = {{ .chezmoi.homeDir }}/.config/git/commit_template
	verbose = true

[core]
	autocrlf = input
	editor = nvim
	eol = lf
	quotePath = true
	{{- if eq .chezmoi.os "windows" }}
	sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
	{{- end }}
	untrackedCache = true
	whitespace = fix,-cr-at-eol,-indent-with-non-tab,space-before-tab,-tab-in-indent,trailing-space

[diff]
	algorithm = patience
	noprefix = true
	renames = copies
	submodule = log

[fetch]
	prune = true
	recurseSubmodules = true

[format]
	graph = true

[gc]
	auto = 1

[git-extras "get"]
	clone-path = {{ .chezmoi.homeDir }}/Code

[github]
	user = {{ (onepasswordDetailsFields "g363lzpne2wne6q2auted2r6we" "" "S5JCIBMKLZDDLDQGA76BYGOZGA").username.value }}
	token = {{ (onepasswordItemFields "g363lzpne2wne6q2auted2r6we" "" "S5JCIBMKLZDDLDQGA76BYGOZGA").jgoguen.value }}

[gpg]
	format = ssh

[gpg "openpgp"]
{{- if eq .chezmoi.os "darwin" }}
	program = {{ if eq .chezmoi.arch "arm64" }}/opt/homebrew{{ else }}/usr/local{{ end }}/bin/gpg
{{- else }}
	program = /usr/bin/gpg2
{{- end }}

[gpg "ssh"]
	allowedSignersFile = {{ .chezmoi.homeDir }}/.config/git/allowed_signers
{{- if eq .chezmoi.os "darwin" }}
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- else if eq .chezmoi.os "windows" }}
	program = "C:/Users/jgogu/AppData/Local/1Password/app/8/op-ssh-sign.exe"
{{- else }}
	program = /opt/1Password/op-ssh-sign
{{- end }}

[grep]
	lineNumber = true
	patternType = perl

[help]
	autocorrect = 1

[http]
	followRedirects = true

[i18n]
	commitEncoding = utf-8
	logOutputEncoding = utf-8

[init]
	defaultBranch = main

[log]
	abbrev-commit = true
	date = iso-local
	decorate = auto

[merge]
	conflictstyle = diff3
	status = true
	summary = true

[pager]
	difftool = true

[pull]
	ff = only
	rebase = true

[push]
	autoSetupRemote = true
	default = current
	forceWithLease = true
	gpgSign = if-asked

[rebase]
	autosquash = true
	autostash = true
	updateRefs = true

[rerere]
	enabled = true

[stash]
	showPatch = true

[status]
	showStash = true
	submoduleSummary = true

[submodule]
	recurse = true

[tag]
	forceSignAnnotated = true
	gpgSign = true

[user]
	name = Joel Goguen
	email = {{ .github.email }}
	signingkey = {{ .github.gpgkey }}

[include]
	path = ~/.config/git/config.local
