# vim: set filetype=zsh:
# Do not edit this file directly! It is managed by chezmoi.

zmodload zsh/complete
zmodload zsh/complist
zmodload zsh/datetime
zmodload zsh/pcre
zmodload zsh/zutil

autoload -U add-zsh-hook
autoload -Uz colors

{{ if eq .chezmoi.os "darwin" -}}
if (( ${+commands[brew]} )); then
	BREW_PREFIX="$(brew --prefix 2>/dev/null || true)"
	export BREW_PREFIX
else
	export BREW_PREFIX=""
fi
{{- end }}

# Only do this if not running in Neovim or the Neovim socket is not available
if [ -z "${NVIM}" ] || [ -S "${NVIM}" ]; then
	for d in "site-functions" "completion"; do
		if [ ! -d "${USER_ZSH}/${d}" ]; then
			/usr/bin/install -d -m 0700 "${USER_ZSH}/${d}"
		fi
	done

	typeset -U fpath
	for d in "${USER_ZSH}/completion" "${USER_ZSH}/site-functions"; do
		if [ -d "${d}" ]; then
			fpath=(${d} ${fpath})
		fi
	done
	{{- if eq .chezmoi.os "darwin" }}
	if [ -n "${BREW_PREFIX}" ]; then
		fpath=(${BREW_PREFIX}/share/zsh/site-functions ${fpath})
	fi
	{{- end }}

	for f in "${USER_ZSH}"/site-functions/*; do
		autoload -U "$(basename "${f%%.zwc}")"
	done
fi

autoload -Uz compinit
# Full rebuild only if zcompdump is older than 24 hours
if [[ -n "${USER_ZSH}/zcompdump"(#qN.mh+24) ]]; then
	compinit -d "${USER_ZSH}/zcompdump"
else
	compinit -C -d "${USER_ZSH}/zcompdump"
fi
